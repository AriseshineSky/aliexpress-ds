# Which developer App to use (selects Redis hash field + token key)
ALIEXPRESS_APP_KEY=your_app_key

# Preferred: Upstash Redis shared with aliexpress-oauth
#   apps:  aliexpress:oauth:apps          (Hash field=app_key → {app_secret,label})
#   token: aliexpress:oauth:token:{app_key}  (auto-refreshed by queue-worker / timer)
# REDIS_URL=rediss://default:PASSWORD@xxxxx.upstash.io:6379

# Optional fallbacks if Redis registry / token missing
# ALIEXPRESS_APP_SECRET=your_app_secret_here
# ALIEXPRESS_ACCESS_TOKEN=your_access_token_here

# Task queue Redis (product_id jobs for enqueue-es / queue-worker) — separate from OAuth
# REDIS_QUEUE_URL=redis://:password@34.133.1.247:6379/0
# REDIS_QUEUE_KEY=aliexpress-ds:products
# REDIS_QUEUE_SEEN_KEY=aliexpress-ds:products:seen
# REDIS_QUEUE_BRPOP_TIMEOUT=5

# IOP gateway for Dropshipping APIs
ALIEXPRESS_API_URL=https://api-sg.aliexpress.com/sync
ALIEXPRESS_SIGN_METHOD=sha256

# Elasticsearch
ES_HOST=34.16.105.219
ES_PORT=9200
ES_USER=your_es_username
ES_PASSWORD=your_es_password
ES_URLS_INDEX=user1_aliexpress_us_product_urls
ES_PRODUCTS_INDEX=user1_aliexpress_us_products
ES_CATEGORIES_INDEX=user1_aliexpress_ds_categories
ES_CRAWL_CATEGORIES_INDEX=user1_aliexpress_crawl_categories

# Official limits (Beijing GMT+8). ALIEXPRESS_DAILY_LIMIT is LOCAL only — API success
# responses do not include remaining quota. Real QPS/ban limits come from error bodies
# (AppApiCallLimit: "This ban will last N seconds"). Match Console 管理证书, or set 0 to disable local daily cap.
ALIEXPRESS_DAILY_LIMIT=100000
ALIEXPRESS_MIN_INTERVAL_SEC=5.0
ALIEXPRESS_MAX_RETRIES=6
# Parallel products in queue-worker (asyncio; shared RateLimiter). 1 = serial.
QUEUE_CONCURRENCY=1

ALIEXPRESS_TRACKING_ID=default

# enqueue-es quality gates (from urls index listing fields)
ENQUEUE_QUALITY_FILTER=1
ENQUEUE_MAX_PRICE=100
ENQUEUE_MIN_RATING=4.4
ENQUEUE_MIN_REVIEWS=1000
ENQUEUE_MIN_SOLD_COUNT=1000
# After quality-pass batch, also enqueue urls missing rating/reviews/sold (queue back)
ENQUEUE_INCLUDE_MISSING_FIELDS=1

# enqueue-es category blacklist (clothing / adult products)
ENQUEUE_CATEGORY_BLACKLIST=1

# Optional enrich after product.get (default off — product detail only).
# FETCH_SHIPPING_FEE=1   # extra API: aliexpress.logistics.buyer.freight.calculate
# FETCH_CATEGORIES=1     # resolve category_id → breadcrumb (ES/tree lookup, not per-product API)
# ENQUEUE_CATEGORY_BLACKLIST_FILE=config/category_blacklist.yaml
# ENQUEUE_CATEGORY_BLACKLIST_KEYWORDS=服装,成人用品,clothing,apparel
