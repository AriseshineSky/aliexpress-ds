# App Console credentials
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_app_secret_here

# Preferred: Upstash Redis (same as aliexpress-oauth TokenStore)
# REDIS_URL=rediss://default:PASSWORD@xxxxx.upstash.io:6379

# Fallback if Redis not set
ALIEXPRESS_ACCESS_TOKEN=your_access_token_here

# IOP gateway for Dropshipping APIs
ALIEXPRESS_API_URL=https://api-sg.aliexpress.com/sync
ALIEXPRESS_SIGN_METHOD=sha256

# Elasticsearch
ES_HOST=34.16.105.219
ES_PORT=9200
ES_USER=your_es_username
ES_PASSWORD=your_es_password
ES_URLS_INDEX=user1_aliexpress_us_product_urls
ES_PRODUCTS_INDEX=user1_aliexpress_us_products
ES_CATEGORIES_INDEX=user1_aliexpress_ds_categories
ES_CRAWL_CATEGORIES_INDEX=user1_aliexpress_crawl_categories

# Official Test / Formal Test Environment: 5,000 API calls per app per day (Beijing GMT+8).
ALIEXPRESS_DAILY_LIMIT=5000
ALIEXPRESS_MIN_INTERVAL_SEC=1.0

ALIEXPRESS_TRACKING_ID=default
